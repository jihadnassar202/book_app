<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../layouts/head') %> 
    <link rel="stylesheet" href="/public/styles/search-phone-view.css">
</head>
<body>
    <%- include('../../layouts/header') %>
    <%- include('../../layouts/drop-menu') %>
        <form id="search-form" action="/searches" method="POST">
        <div class="Search-container">
            <h1>Book Search</h1>
            <h2>Search for a book by title or author</h2>
        <input type="text" name="name" placeholder="SEARCH BY NAME OR AUTHOR" required>
        <div class="radio-container">
            <input type="radio" name="type" value="name" id="name" required>
            <label for="Title" required>TITLE</label>
            <input type="radio" name="type" value="Author" id="Author" required>
            <label for="Author" required>AUTHOR</label>
        </div>
               <input type="submit" value="SEARCH">
    </form>
  </div>
  <%- include('../../layouts/footer') %>
</body>
</html>
