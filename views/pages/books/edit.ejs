<div class="modal" id="edit-book-modal">
    <div class="modal-content">
        <form action="/books/<%= book.id %>" method="post">
            <input type="hidden" name="_method" value="PUT">
            <input type="text" name="title" value="<%= book.title %>">
            <input type="text" name="author" value="<%= book.author %>">
            <input type="text" name="image" value="<%= book.image %>">
            <input type="text" name="description" value="<%= book.description %>">
            <input type="text" name="isbn" value="<%= book.isbn %>">
            <input type="text" name="category" value="<%= book.category %>">
            <button type="submit" class="update-button" id="update-book-button">Update Book</button>

        </form>
    </div>
   </div>